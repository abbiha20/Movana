rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // In development, we allow open read/write access to allow client-side lookup and creation of records.
    // For a production deployment, these rules should be updated to restrict writes to authenticated users.
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /shipments/{shipmentId} {
      allow read, write: if true;
    }
    
    match /bids/{bidId} {
      allow read, write: if true;
    }
    
    match /negotiations/{negotiationId} {
      allow read, write: if true;
    }
    
    match /violations/{violationId} {
      allow read, write: if true;
    }
    
    match /activityLogs/{logId} {
      allow read, write: if true;
    }
    
    match /ratings/{ratingId} {
      allow read, write: if true;
    }
  }
}
